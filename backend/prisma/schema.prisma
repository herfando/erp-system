generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/* ================= PRODUCT ================= */
model Product {
  id        String   @id @default(cuid())
  name      String
  type      String
  unit      String
  createdAt DateTime @default(now())

  stocks            Stock[]
  movements         StockMovement[]
  productionOrders  ProductionOrder[]
  salesOrders       SalesOrder[]
}

/* ================= STOCK ================= */
model Stock {
  id        String  @id @default(cuid())
  productId String
  quantity  Int

  product   Product @relation(fields: [productId], references: [id])
}

/* ================= STOCK MOVEMENT ================= */
model StockMovement {
  id        String   @id @default(cuid())
  productId String
  type      String
  quantity  Int
  reason    String
  createdAt DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id])
}

/* ================= PRODUCTION ================= */
model ProductionOrder {
  id        String   @id @default(cuid())
  productId String
  quantity  Int
  status    String
  createdAt DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id])
}

/* ================= SALES ================= */
model SalesOrder {
  id        String   @id @default(cuid())
  customer  String
  productId String
  quantity  Int
  status    String
  createdAt DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id])
}